<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/app_primary_container" />
            <corners android:radius="14dp" />
            <stroke
                android:width="1dp"
                android:color="@color/app_outline" />
        </shape>
    </item>

    <item
        android:drawable="@drawable/ic_spinner_chevron"
        android:gravity="end|center_vertical"
        android:right="14dp"
        android:width="24dp"
        android:height="24dp" />
</layer-list>

