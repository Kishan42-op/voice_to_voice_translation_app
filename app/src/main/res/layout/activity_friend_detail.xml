<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/app_background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarFriendDetail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:title="@string/friend_detail_title"
        app:titleTextColor="@color/app_on_surface"
        app:backgroundTint="@color/app_background" />

    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/progressFriendDetail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="32dp"
        android:visibility="gone"
        app:indicatorColor="@color/app_primary" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <!-- Large Avatar -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardFriendAvatar"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_marginBottom="24dp"
                android:layout_gravity="center_horizontal"
                app:cardBackgroundColor="@color/app_primary_container"
                app:cardCornerRadius="70dp"
                app:cardElevation="4dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center">

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvFriendDetailInitials"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:textSize="56sp"
                        android:textStyle="bold"
                        android:textColor="@color/app_on_primary_container"
                        android:text="@string/friend_detail_avatar_fallback" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Friend Info Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="@color/app_surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/app_outline"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center_horizontal">

                    <!-- Username -->
                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvFriendDetailUsername"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/app_primary" />

                    <!-- Name -->
                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvFriendDetailName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textSize="16sp"
                        android:textColor="@color/app_on_surface" />

                    <!-- Email -->
                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvFriendDetailEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textSize="13sp"
                        android:textColor="@color/app_on_surface_variant" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="4dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFriendDetailCall"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="@string/friend_detail_call_button"
                    android:textSize="15sp"
                    app:icon="@drawable/ic_call"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp"
                    app:iconTint="@color/app_on_primary"
                    app:backgroundTint="@color/app_primary"
                    android:textColor="@color/app_on_primary"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFriendDetailMessage"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="@string/friend_detail_message_button"
                    android:textSize="15sp"
                    app:strokeColor="@color/app_primary"
                    android:textColor="@color/app_primary"
                    app:cornerRadius="12dp" />
            </LinearLayout>

            <!-- Placeholder Sections for Future -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="@string/friend_detail_info"
                android:textStyle="bold"
                android:textColor="@color/app_on_surface"
                android:textSize="14sp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/app_surface_variant"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:gravity="center">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/friend_detail_coming_soon"
                        android:textColor="@color/app_on_surface_variant"
                        android:textSize="13sp" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>

</LinearLayout>

