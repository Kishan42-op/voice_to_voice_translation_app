<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardContactItem"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/app_surface"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/app_outline"
    app:strokeWidth="1dp"
    app:rippleColor="@color/app_primary_container">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Avatar Circle with Initials -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardContactAvatar"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="14dp"
            app:cardBackgroundColor="@color/app_primary_container"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvContactInitials"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_gravity="center"
                    android:textColor="@color/app_on_primary_container"
                    android:text="U" />
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Contact Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="12dp">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvContactUsername"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/app_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvContactName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:textColor="@color/app_on_surface"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvContactEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:textColor="@color/app_on_surface_variant"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Call Button Icon -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContactCall"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="center_vertical"
            android:minWidth="44dp"
            android:minHeight="44dp"
            android:padding="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_call"
            app:iconPadding="0dp"
            app:iconGravity="textEnd"
            app:iconSize="24dp"
            app:iconTint="@color/app_primary"
            app:borderWidth="2dp"
            app:strokeColor="@color/app_primary"
            app:backgroundTint="@color/app_surface"
            app:cornerRadius="22dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>



